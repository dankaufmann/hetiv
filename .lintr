linters: linters_with_tags(
    c("correctness", "robustness"),
    object_usage_linter = NULL,
    T_and_F_symbol_linter = NULL,
    object_overwrite_linter = NULL,
    undesirable_function_linter = NULL
  )
exclusions: list(
    "docs",
    "vignettes/hetiv-introduction.html",
    "vignettes/hetiv-introduction.Rmd"
  )
